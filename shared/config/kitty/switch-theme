#!/usr/bin/env sh
set -eu

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/kitty"
state_file="$config_dir/theme.conf"
config_file="$config_dir/kitty.conf"
kitty_targets="${KITTY_LISTEN_ON:-} unix:/tmp/kitty-main"

read_theme() {
    awk '/^[[:space:]]*#[[:space:]]*tsp_theme[[:space:]]+/ { print $3; exit }' "$state_file" 2>/dev/null || true
}

write_theme() {
    theme="$1"
    case "$theme" in
        gruber_darker)
            include="themes/gruber-darker.conf"
            opacity="1.0"
            blur="0"
            transparency="true"
            ;;
        solarized_dark)
            include="themes/solarized-dark.conf"
            opacity="1.0"
            blur="0"
            transparency="true"
            ;;
        *)
            echo "unknown theme: $theme" >&2
            exit 1
            ;;
    esac

    tmp_file="${state_file}.tmp.$$"
    {
        echo "# Generated by switch-theme. Edit the values here if you want a different persisted state."
        echo "# tsp_theme $theme"
        echo "# tsp_transparency $transparency"
        echo "# tsp_transparency_opacity $opacity"
        echo "# tsp_transparency_blur $blur"
        echo "include $include"
        echo "background_opacity $opacity"
        echo "background_blur $blur"
        echo "dynamic_background_opacity yes"
    } > "$tmp_file"
    mv "$tmp_file" "$state_file"
}

reload_nvim() {
    runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
    for server in "$runtime_dir"/nvim.*.0 "$runtime_dir"/nvim.*.*/0 "$runtime_dir"/nvim.*/0 /tmp/nvim.*.0 /tmp/nvim.*.*/0 /tmp/nvim.*/0; do
        [ -S "$server" ] || continue
        nvim --server "$server" --remote-expr 'execute("TspReloadTheme")' >/dev/null 2>&1 || true
    done
}

mkdir -p "$config_dir"

current_theme="$(read_theme)"
if [ -z "$current_theme" ]; then
    current_theme="solarized_dark"
    write_theme "$current_theme"
fi

case "$current_theme" in
    solarized_dark) next_theme="gruber_darker" ;;
    *) next_theme="solarized_dark" ;;
esac

write_theme "$next_theme"

opacity="$(awk '/^[[:space:]]*background_opacity[[:space:]]+/ { print $2; exit }' "$state_file")"

for kitty_to in $kitty_targets; do
    [ -n "$kitty_to" ] || continue
    kitty @ --to "$kitty_to" set-colors --all --configured "$state_file" >/dev/null 2>&1 || continue
    kitty @ --to "$kitty_to" set-background-opacity --all "$opacity" >/dev/null 2>&1 || true
    kitty @ --to "$kitty_to" load-config "$config_file" >/dev/null 2>&1 || true
    break
done

reload_nvim
